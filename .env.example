# Bungie API credentials. Copy to .env and fill in.
#
# For the Chrome extension we recommend registering a *public* (confidential=false)
# Bungie OAuth client — the client secret cannot be protected in a client-side
# extension. If you reuse the existing confidential client, set VITE_BUNGIE_CLIENT_SECRET
# and ship accepting the risk. Otherwise leave it empty and the extension will
# send only client_id on the token exchange.
VITE_BUNGIE_API_KEY=
VITE_BUNGIE_CLIENT_ID=
VITE_BUNGIE_CLIENT_SECRET=
