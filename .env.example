# Bungie API credentials. Copy to .env and fill in.
#
# Brief #22: the extension uses the cryptarch-auth Cloudflare Worker as a
# token broker for the confidential OAuth flow. The client_secret stays in
# the Worker's secrets; the extension only needs the public client_id and
# the Worker's URL.
VITE_BUNGIE_API_KEY=
VITE_BUNGIE_CLIENT_ID=
VITE_AUTH_WORKER_URL=
